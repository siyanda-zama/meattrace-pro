# MeatTrace Pro — Environment Variables
# Copy this file to .env and fill in values

# App
VITE_APP_NAME=MeatTrace Pro
VITE_APP_VERSION=1.0.0

# API (future — currently uses mock data)
VITE_API_BASE_URL=https://api.meattracepro.com
VITE_API_TIMEOUT=30000

# Feature flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_BLE_SIMULATION=true
VITE_ENABLE_IOT_SIMULATION=true
